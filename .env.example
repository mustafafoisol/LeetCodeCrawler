# Copy this file to .env and fill in your real LeetCode credentials.
# Never commit .env — it is listed in .gitignore.
#
# How to get these values:
#   1. Log in to leetcode.com in your browser
#   2. Open DevTools → Application → Cookies → leetcode.com
#   3. Copy the values for LEETCODE_SESSION and csrftoken

LEETCODE_SESSION=paste_your_leetcode_session_here
CSRF_TOKEN=paste_your_csrf_token_here

# Directory where summary .txt files are saved (created automatically if missing)
SUMMARY_DIR=./summaries
